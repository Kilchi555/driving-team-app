# fastlane/Fastfile
# Fastlane configuration for white-label iOS builds.
# Reads CLIENT env var to load the correct client config.

# Load root .env for local development (ignored in CI where secrets are injected)
root_env = File.join(File.dirname(__FILE__), '..', '.env')
if File.exist?(root_env)
  File.readlines(root_env).each do |line|
    line = line.strip
    next if line.empty? || line.start_with?('#')
    key, val = line.split('=', 2)
    ENV[key] = val if key && val && ENV[key].nil?
  end
end

default_platform(:ios)

# ─── Helper: Load client config ──────────────────────────────────────────────

def load_client_config
  client_id = ENV['CLIENT'] || 'driving-team'
  config_path = File.join(File.dirname(__FILE__), '..', 'clients', client_id, 'config.json')

  unless File.exist?(config_path)
    UI.user_error!("Client config not found: #{config_path}")
  end

  require 'json'
  JSON.parse(File.read(config_path))
end

# ─── iOS Platform ─────────────────────────────────────────────────────────────

platform :ios do

  # ---------------------------------------------------------------------------
  # sync_certificates: Downloads or creates provisioning profiles via Match
  # ---------------------------------------------------------------------------
  lane :sync_certificates do
    client = load_client_config

    match(
      type:                'appstore',
      app_identifier:      client['bundleId'],
      git_url:             ENV['MATCH_GIT_URL'],
      git_basic_authorization: Base64.strict_encode64("x-access-token:#{ENV['MATCH_GIT_TOKEN']}"),
      readonly:            is_ci,                    # Don't create new certs in CI
      team_id:             ENV['APPLE_TEAM_ID'],
      api_key_path:        nil,
      api_key: {
        key_id:      ENV['APPLE_API_KEY_ID'],
        issuer_id:   ENV['APPLE_API_ISSUER_ID'],
        key_content: ENV['APPLE_API_KEY_CONTENT'] || File.read(
          File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ENV['APPLE_API_KEY_ID']}.p8")
        ),
        is_key_content_base64: !!ENV['APPLE_API_KEY_CONTENT'],
        in_house: false,
      }
    )
  end

  # ---------------------------------------------------------------------------
  # create_app: Creates a new app in App Store Connect (run once per client)
  # ---------------------------------------------------------------------------
  lane :create_app do
    client = load_client_config

    api_key = app_store_connect_api_key(
      key_id:        ENV['APPLE_API_KEY_ID'],
      issuer_id:     ENV['APPLE_API_ISSUER_ID'],
      key_filepath:  File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ENV['APPLE_API_KEY_ID']}.p8"),
      in_house:      false,
    )

    produce(
      app_identifier: client['bundleId'],
      app_name:       client['appName'],
      language:       'German',
      app_version:    client['version'],
      sku:            client['clientId'],
      team_id:        ENV['APPLE_TEAM_ID'],
    )
  end

  # ---------------------------------------------------------------------------
  # deploy: Full pipeline — build, upload to TestFlight or App Store
  #
  # Uses Xcode's "Automatic Signing" (CODE_SIGN_STYLE = Automatic) — no Match
  # setup required. Xcode itself pulls certs/profiles from Apple Developer
  # Portal at build time, using the team configured via DEVELOPMENT_TEAM
  # in project.pbxproj.
  #
  # If you ever want a deterministic, git-managed certs/profiles workflow,
  # set up Match and re-enable the `sync_certificates` lane.
  # ---------------------------------------------------------------------------
  lane :deploy do
    client     = load_client_config
    target     = ENV['DEPLOY_TARGET'] || 'testflight'
    version    = client['version']
    bundle_id  = client['bundleId']
    app_name   = client['appName']

    UI.message("🚀 Deploying #{app_name} (#{bundle_id}) v#{version} → #{target}")

    # Build App Store Connect API key — used for both signing (build_app) and upload
    api_key = app_store_connect_api_key(
      key_id:        ENV['APPLE_API_KEY_ID'],
      issuer_id:     ENV['APPLE_API_ISSUER_ID'],
      key_filepath:  File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ENV['APPLE_API_KEY_ID']}.p8"),
      in_house:      false,
    )

    # 1. Generate capacitor.config.json + sync iOS project for the right client
    sh("cd .. && CLIENT=#{client['clientId']} node scripts/gen-cap-config.mjs")
    sh('cd .. && npx cap sync ios')

    # 2. Update version and build number
    increment_version_number(
      version_number: version,
      xcodeproj: 'ios/App/App.xcodeproj'
    )
    increment_build_number(
      build_number: Time.now.strftime('%Y%m%d%H%M'),
      xcodeproj: 'ios/App/App.xcodeproj'
    )

    # 2b. Patch per-client display name in Info.plist
    set_info_plist_value(
      path: 'ios/App/App/Info.plist',
      key: 'CFBundleDisplayName',
      value: app_name
    )

    # 2c. Strip Dev-only App Transport Security exceptions (NSAllowsArbitraryLoads etc.)
    #     They are required for local Live-Reload but Apple may reject the submission otherwise.
    #     The original Info.plist is backed up to Info.plist.bak and restored after the build.
    sh('cd .. && fastlane/strip-ats.sh')

    # 3. Build the app (SPM-based project — no .xcworkspace)
    #    Automatic signing: api_key lets Xcode pull the Distribution profile from
    #    Apple Developer Portal at build time (no local Distribution cert required).
    build_app(
      project:              'ios/App/App.xcodeproj',
      scheme:               'App',
      configuration:        'Release',
      export_method:        'app-store',
      output_directory:     './build',
      output_name:          "#{client['clientId']}.ipa",
      clean:                true,
      xcargs:               "-allowProvisioningUpdates DEVELOPMENT_TEAM='#{ENV['APPLE_TEAM_ID']}'",
      export_options: {
        signingStyle:                 'automatic',
        teamID:                       ENV['APPLE_TEAM_ID'],
        uploadBitcode:                false,
        uploadSymbols:                true,
        compileBitcode:               false,
      }
    )

    if target == 'appstore'
      # 4a. Upload to App Store (requires metadata)
      deliver(
        api_key:                    api_key,
        app_identifier:             bundle_id,
        ipa:                        "./build/#{client['clientId']}.ipa",
        submit_for_review:          false,
        automatic_release:          false,
        force:                      true,
        skip_screenshots:           true,
        skip_metadata:              true,
        run_precheck_before_submit: false,
      )
      UI.success("✅ #{app_name} uploaded to App Store (pending review)")
    else
      # 4b. Upload to TestFlight
      upload_to_testflight(
        api_key:      api_key,
        ipa:          "./build/#{client['clientId']}.ipa",
        skip_waiting_for_build_processing: true,
      )
      UI.success("✅ #{app_name} uploaded to TestFlight")
    end
  end

  # ---------------------------------------------------------------------------
  # upload_metadata: Upload only metadata (description, keywords, release notes)
  # without rebuilding or re-uploading the binary. Skips app name (already set).
  # Usage: CLIENT=simy bundle exec fastlane upload_metadata
  # ---------------------------------------------------------------------------
  lane :upload_metadata do
    client  = load_client_config
    bundle_id = client['bundleId']

    api_key = app_store_connect_api_key(
      key_id:        ENV['APPLE_API_KEY_ID'],
      issuer_id:     ENV['APPLE_API_ISSUER_ID'],
      key_filepath:  File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ENV['APPLE_API_KEY_ID']}.p8"),
      in_house:      false,
    )

    # Temporarily hide name.txt files so deliver doesn't try to update the app name
    # (Apple rejects name changes if it's already registered by another app)
    name_files = Dir.glob("../clients/#{client['clientId']}/metadata/**/name.txt")
    name_files.each { |f| File.rename(f, "#{f}.bak") }

    begin
      deliver(
        api_key:                    api_key,
        app_identifier:             bundle_id,
        skip_binary_upload:         true,
        skip_screenshots:           true,
        skip_metadata:              false,
        submit_for_review:          false,
        automatic_release:          false,
        force:                      true,
        run_precheck_before_submit: false,
        metadata_path:              "./clients/#{client['clientId']}/metadata",
      )
      UI.success("✅ Metadata uploaded for #{client['appName']}")
    ensure
      name_files.each { |f| File.rename("#{f}.bak", f) if File.exist?("#{f}.bak") }
    end
  end

  # ---------------------------------------------------------------------------
  # After all: Restore Info.plist (Dev ATS exceptions) — always runs after a lane
  # ---------------------------------------------------------------------------
  after_all do |lane, options|
    # Restore the Dev-only Info.plist (with NSAllowsArbitraryLoads) so local Live-Reload
    # keeps working after a release build.
    if File.exist?('../ios/App/App/Info.plist.bak')
      sh('cd .. && fastlane/restore-ats.sh')
    end
  end

  # ---------------------------------------------------------------------------
  # Error handler — also restore Info.plist on failure
  # ---------------------------------------------------------------------------
  error do |lane, exception, options|
    UI.error("❌ Lane '#{lane}' failed: #{exception.message}")
    if File.exist?('../ios/App/App/Info.plist.bak')
      sh('cd .. && fastlane/restore-ats.sh')
    end
  end

end
