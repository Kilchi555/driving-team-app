{
  "redirects": [
    {
      "source": "/((?!_nuxt/|_payload|api/|fahrschule|marketing|coaches|therapeuten|preise|demo|kunden|blog|kontakt|impressum|agb|datenschutz|features|ueber-uns|partner|coaching|sitemap).+)",
      "destination": "https://app.simy.ch/$1",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/_nuxt/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/((?!_nuxt).*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ]
}
