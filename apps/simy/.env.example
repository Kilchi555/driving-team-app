# Existing variables
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@simy.ch
STRIPE_SECRET_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# Google Analytics 4
# Get from: analytics.google.com → Admin → Data Streams → your stream → Measurement ID
# nuxt-gtag reads NUXT_PUBLIC_GTAG_ID natively — set this one in Vercel
NUXT_PUBLIC_GTAG_ID=G-XXXXXXXXXX
# fallback (legacy name, still supported)
NUXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console site verification
# Get from: search.google.com/search-console → Add property → HTML meta tag method → copy content value
NUXT_PUBLIC_GSC_VERIFICATION=
