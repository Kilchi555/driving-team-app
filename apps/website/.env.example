# Lokale Umgebungsvariablen – wird NICHT committed (in .gitignore)
# Kopiere diese Datei nach .env im Ordner apps/website und fülle die Werte aus.
# Danach Dev-Server neu starten (nuxt lädt .env beim Start).

# Supabase (Kurs-APIs, Kontaktformular, Analytics) – Service Role nur serverseitig, nie im Browser
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Nuxt überschreibt runtimeConfig (gleiche Wirkung wie die Variablen oben)
# NUXT_SUPABASE_URL=
# NUXT_SUPABASE_SERVICE_ROLE_KEY=

# Bestehender Google Maps Key (für Karte auf der Website)
VITE_GOOGLE_MAPS_API_KEY=

# Neuer Server-Only Key für Places API (ohne Referrer-Restriction)
# → https://console.cloud.google.com → Credentials → Create API Key
# → API Restriction: nur "Places API" aktivieren, KEIN HTTP Referrer
GOOGLE_PLACES_API_KEY=

# Place IDs der Standorte
GOOGLE_PLACE_ID_ZUERICH=ChIJU29cFMgLkEcRzMfDub2bh9s
GOOGLE_PLACE_ID_LACHEN=ChIJqdlnJXTJmkcRAgI05nvPXFU
