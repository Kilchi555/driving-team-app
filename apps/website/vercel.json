{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.drivingteam.ch"
        }
      ],
      "destination": "https://drivingteam.ch/:path*",
      "permanent": true
    },
    {
      "source": "/autoshkolle-shqipe",
      "destination": "https://drivingteam.ch/auto-fahrschule/",
      "permanent": true
    },
    {
      "source": "/autoshkolle-shqipe/",
      "destination": "https://drivingteam.ch/auto-fahrschule/",
      "permanent": true
    },
    {
      "source": "/blog/undefined",
      "destination": "https://drivingteam.ch/blog/",
      "permanent": true
    },
    {
      "source": "/blog/undefined/",
      "destination": "https://drivingteam.ch/blog/",
      "permanent": true
    },
    {
      "source": "/drivers-license-converting",
      "destination": "https://drivingteam.ch/blog/drivers-license-convert/",
      "permanent": true
    },
    {
      "source": "/drivers-license-converting/",
      "destination": "https://drivingteam.ch/blog/drivers-license-convert/",
      "permanent": true
    },
    {
      "source": "/blog-minderung-pruefungsangst",
      "destination": "https://drivingteam.ch/blog/pruefungsangst-fahrpruefung/",
      "permanent": true
    },
    {
      "source": "/blog-minderung-pruefungsangst/",
      "destination": "https://drivingteam.ch/blog/pruefungsangst-fahrpruefung/",
      "permanent": true
    },
    {
      "source": "/fahrschueler-respekt-geduld",
      "destination": "https://drivingteam.ch/blog/",
      "permanent": true
    },
    {
      "source": "/fahrschueler-respekt-geduld/",
      "destination": "https://drivingteam.ch/blog/",
      "permanent": true
    },
    {
      "source": "/wp-content/:path*",
      "destination": "https://drivingteam.ch/",
      "permanent": true
    },
    {
      "source": "/wp-includes/:path*",
      "destination": "https://drivingteam.ch/",
      "permanent": true
    },
    {
      "source": "/wp-admin/:path*",
      "destination": "https://drivingteam.ch/",
      "permanent": true
    },
    {
      "source": "/wp-login.php",
      "destination": "https://drivingteam.ch/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/_nuxt/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/((?!_nuxt|images|favicon).*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
