{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self), payment=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://maps.googleapis.com https://js.hcaptcha.com https://app-wallee.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https: blob:; connect-src 'self' https://unyjaetebnaexaflpyoc.supabase.co https://maps.googleapis.com https://hcaptcha.com https://api.resend.com https://app-wallee.com wss://unyjaetebnaexaflpyoc.supabase.co; font-src 'self' data: https://fonts.gstatic.com; frame-src 'self' https://js.hcaptcha.com https://app-wallee.com; media-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self' https://app-wallee.com"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/cleanup-expired-invitations",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/calculate-availability",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/process-recalc-queue",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/sync-external-calendars",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/sync-sari-courses",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/process-affiliate-rewards",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/process-outbound-messages",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/send-onboarding-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/send-appointment-reminders",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/send-payment-reminders",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/send-overdue-payment-reminders",
      "schedule": "5 7 * * *"
    },
    {
      "path": "/api/cron/send-admin-payment-report",
      "schedule": "0 6 * * 1"
    }
  ],
  "rewrites": [
    {
      "source": "/register-staff",
      "destination": "/register/staff"
    }
  ]
}
